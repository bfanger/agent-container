{
  "$schema": "https://opencode.ai/config.json",
  "model": "llama-swap/Qwen3.6-27B-Fast",
  "provider": {
    "llama-swap": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-swap",
      "options": {
        "baseURL": "http://host.docker.internal:8080/v1"
      },
      "models": {
        "Qwen3.6-27B-Fast": {
          "name": "Qwen3.6 27B Fast (MTP 40K)",
          "limit": {
            "context": 40000,
            "input": 40000,
            "output": 32000
          }
        },
        "Qwen3.6-27B-Turbo": {
          "name": "Qwen3.6 27B Turbo (MTP 50K)",
          "limit": {
            "context": 50000,
            "input": 50000,
            "output": 32000
          }
        },
        "Qwen3.6-27B-Vision": {
          "name": "Qwen3.6 27B Vision",
          "limit": {
            "context": 10000,
            "input": 10000,
            "output": 32000
          }
        },
        "Qwen3.6-27B-Balanced": {
          "name": "Qwen3.6 27B (50K)",
          "limit": {
            "context": 50000,
            "input": 50000,
            "output": 32000
          }
        },
        "Qwen3.6-27B-Mini": {
          "name": "Qwen3.6 27B Mini (16K)",
          "limit": {
            "context": 16000,
            "input": 16000,
            "output": 32000
          }
        },
        "Qwen3.6-27B-Max": {
          "name": "Qwen3.6 27B Max (68K)",
          "limit": {
            "context": 68000,
            "input": 68000,
            "output": 32000
          }
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--browser=firefox"],
      "enabled": false
    }
  }
}
