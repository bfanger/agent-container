{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://host.docker.internal:8080/v1"
      },
      "models": {
        "unsloth/Qwen3.5-27B-GGUF": {
          "name": "Qwen 3.5 27B",
          "limit": {
            "context": 64000,
            "output": 32000
          }
        },
        "GLM-4.7-Flash-UD-IQ3_XXS.gguf": {
          "name": "GLM 4.7 Flash",
          "limit": {
            "context": 50000,
            "output": 32000
          }
        },
        "unknown": {
          "name": "Unknown model"
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--browser=firefox"],
      "enabled": false
    }
  }
}
